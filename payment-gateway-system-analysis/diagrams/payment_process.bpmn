          <dc:Bounds x="1029" y="557" width="14" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_Fail" bpmnElement="Gateway_Flow_Fail">
        <di:waypoint x="1080" y="625" />
        <di:waypoint x="1053" y="625" />
        <di:waypoint x="1053" y="695" />
        <di:waypoint x="1025" y="695" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1029" y="658" width="19" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_11" bpmnElement="Gateway_Flow_11">
        <di:waypoint x="875" y="595" />
        <di:waypoint x="815" y="595" />
        <di:waypoint x="815" y="625" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_12" bpmnElement="Gateway_Flow_12">
        <di:waypoint x="875" y="695" />
