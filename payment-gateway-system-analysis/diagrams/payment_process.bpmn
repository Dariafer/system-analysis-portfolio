        <di:waypoint x="570" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_Existing" bpmnElement="Gateway_Flow_Existing">
        <di:waypoint x="595" y="460" />
        <di:waypoint x="595" y="355" />
        <di:waypoint x="650" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_Existing_2" bpmnElement="Gateway_Flow_Existing_2">
        <di:waypoint x="800" y="355" />
        <di:waypoint x="830" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_Existing_3" bpmnElement="Gateway_Flow_Existing_3">
        <di:waypoint x="970" y="355" />
        <di:waypoint x="1010" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_New" bpmnElement="Gateway_Flow_New">
        <di:waypoint x="620" y="485" />
        <di:waypoint x="650" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_4" bpmnElement="Gateway_Flow_4">
        <di:waypoint x="800" y="485" />
        <di:waypoint x="830" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_5" bpmnElement="Gateway_Flow_5">
        <di:waypoint x="980" y="485" />
        <di:waypoint x="1010" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_6" bpmnElement="Gateway_Flow_6">
        <di:waypoint x="1160" y="485" />
        <di:waypoint x="1190" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_7" bpmnElement="Gateway_Flow_7">
        <di:waypoint x="1330" y="485" />
        <di:waypoint x="1370" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_8" bpmnElement="Gateway_Flow_8">
        <di:waypoint x="1510" y="485" />
        <di:waypoint x="1550" y="485" />
        <di:waypoint x="1550" y="607" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_9" bpmnElement="Gateway_Flow_9">
        <di:waypoint x="1532" y="625" />
        <di:waypoint x="1340" y="625" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_10" bpmnElement="Gateway_Flow_10">
        <di:waypoint x="1190" y="625" />
        <di:waypoint x="1130" y="625" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_Success" bpmnElement="Gateway_Flow_Success">
        <di:waypoint x="1080" y="625" />
        <di:waypoint x="1053" y="625" />
        <di:waypoint x="1053" y="580" />
        <di:waypoint x="1025" y="580" />
