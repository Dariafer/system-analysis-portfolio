      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_14" bpmnElement="Gateway_Flow_14">
        <di:waypoint x="620" y="650" />
        <di:waypoint x="580" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_15" bpmnElement="Gateway_Flow_15">
        <di:waypoint x="440" y="650" />
        <di:waypoint x="400" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_16" bpmnElement="Gateway_Flow_16">
        <di:waypoint x="260" y="650" />
        <di:waypoint x="216" y="650" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Participant_Bank" bpmnElement="Participant_Bank" isHorizontal="true">
        <dc:Bounds x="120" y="790" width="1620" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bank_ProcessPayment" bpmnElement="Bank_ProcessPayment">
        <dc:Bounds x="1340" y="815" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Bank_SendCallback" bpmnElement="Bank_SendCallback">
