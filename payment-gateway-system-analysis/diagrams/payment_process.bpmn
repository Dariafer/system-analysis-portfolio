      <bpmndi:BPMNShape id="Shape_Gateway_CreatePayment" bpmnElement="Gateway_CreatePayment">
        <dc:Bounds x="650" y="445" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SaveIdempotency" bpmnElement="Gateway_SaveIdempotency">
        <dc:Bounds x="830" y="445" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_CreateAttempt" bpmnElement="Gateway_CreateAttempt">
        <dc:Bounds x="1010" y="445" width="150" height="80" />
