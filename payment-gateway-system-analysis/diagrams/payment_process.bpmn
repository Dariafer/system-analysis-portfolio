      <bpmndi:BPMNShape id="Shape_Gateway_ResultGateway" bpmnElement="Gateway_ResultGateway" isMarkerVisible="true">
        <dc:Bounds x="1080" y="600" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SetSucceeded" bpmnElement="Gateway_SetSucceeded">
        <dc:Bounds x="875" y="555" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SetFailed" bpmnElement="Gateway_SetFailed">
        <dc:Bounds x="875" y="655" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_StatusJoin" bpmnElement="Gateway_StatusJoin" isMarkerVisible="true">
        <dc:Bounds x="790" y="625" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_CreateWebhookEvent" bpmnElement="Gateway_CreateWebhookEvent">
        <dc:Bounds x="620" y="610" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SendWebhook" bpmnElement="Gateway_SendWebhook">
        <dc:Bounds x="440" y="610" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_MarkWebhookSent" bpmnElement="Gateway_MarkWebhookSent">
        <dc:Bounds x="260" y="610" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_End" bpmnElement="Gateway_End">
        <dc:Bounds x="180" y="632" width="36" height="36" />
