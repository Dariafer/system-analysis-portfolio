<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_PaymentGateway" targetNamespace="http://example.com/payment-gateway" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_PaymentGateway">
    <bpmn:participant id="Participant_Merchant" name="Мерчант" processRef="Process_Merchant" />
    <bpmn:participant id="Participant_Gateway" name="Payment Gateway" processRef="Process_Gateway" />
    <bpmn:participant id="Participant_Bank" name="Заглушка банка-эквайера" processRef="Process_Bank" />
    <bpmn:participant id="Participant_MerchantSystem" name="Система мерчанта" processRef="Process_MerchantSystem" />
    <bpmn:messageFlow id="MessageFlow_CreatePayment" name="POST /api/v1/payments" sourceRef="Merchant_SendCreatePayment" targetRef="Gateway_Start" />
    <bpmn:messageFlow id="MessageFlow_PaymentResponse" name="201 Created / 200 OK" sourceRef="Gateway_SendPaymentResponse" targetRef="Merchant_ReceivePaymentResponse" />
    <bpmn:messageFlow id="MessageFlow_ToBank" name="Запрос на оплату" sourceRef="Gateway_SendToBank" targetRef="Bank_ProcessPayment" />
    <bpmn:messageFlow id="MessageFlow_Callback" name="POST /api/v1/acquiring/callback" sourceRef="Bank_SendCallback" targetRef="Gateway_CatchCallback" />
    <bpmn:messageFlow id="MessageFlow_Webhook" name="POST webhook_url" sourceRef="Gateway_SendWebhook" targetRef="MerchantSystem_ReceiveWebhook" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Merchant" isExecutable="false">
    <bpmn:startEvent id="Merchant_Start" name="Нужно создать платеж" />
    <bpmn:sendTask id="Merchant_SendCreatePayment" name="Отправить запрос на создание платежа" />
    <bpmn:receiveTask id="Merchant_ReceivePaymentResponse" name="Получить ответ по платежу" />
    <bpmn:endEvent id="Merchant_End" name="Ответ получен" />
    <bpmn:sequenceFlow id="Merchant_Flow_1" sourceRef="Merchant_Start" targetRef="Merchant_SendCreatePayment" />
    <bpmn:sequenceFlow id="Merchant_Flow_2" sourceRef="Merchant_SendCreatePayment" targetRef="Merchant_ReceivePaymentResponse" />
    <bpmn:sequenceFlow id="Merchant_Flow_3" sourceRef="Merchant_ReceivePaymentResponse" targetRef="Merchant_End" />
  </bpmn:process>
  <bpmn:process id="Process_Gateway" isExecutable="false">
    <bpmn:dataStoreReference id="DataStore_PostgreSQL" name="PostgreSQL" />
    <bpmn:startEvent id="Gateway_Start" name="Запрос на создание платежа" />
    <bpmn:serviceTask id="Gateway_CheckApiKey" name="Проверить X-API-Key" />
    <bpmn:serviceTask id="Gateway_CheckIdempotency" name="Проверить Idempotency-Key" />
    <bpmn:exclusiveGateway id="Gateway_IdempotencyGateway" name="Ключ уже использовался?" />
    <bpmn:serviceTask id="Gateway_GetExistingPayment" name="Получить ранее созданный платеж" />
    <bpmn:sendTask id="Gateway_SendPaymentResponse" name="Вернуть ответ мерчанту" />
    <bpmn:endEvent id="Gateway_EndExisting" name="Повторный запрос обработан" />
    <bpmn:serviceTask id="Gateway_CreatePayment" name="Создать payment со статусом CREATED" />
    <bpmn:serviceTask id="Gateway_SaveIdempotency" name="Создать запись idempotency_key" />
    <bpmn:serviceTask id="Gateway_CreateAttempt" name="Создать payment_attempt" />
    <bpmn:serviceTask id="Gateway_SetProcessing" name="Установить статус PROCESSING" />
    <bpmn:sendTask id="Gateway_SendToBank" name="Отправить запрос в банк-эквайер" />
    <bpmn:serviceTask id="Gateway_FindAttempt" name="Найти payment_attempt по acquiring_request_id" />
    <bpmn:exclusiveGateway id="Gateway_ResultGateway" name="Результат успешный?" />
    <bpmn:serviceTask id="Gateway_SetSucceeded" name="Установить статус SUCCEEDED" />
    <bpmn:serviceTask id="Gateway_SetFailed" name="Установить статус FAILED" />
    <bpmn:exclusiveGateway id="Gateway_StatusJoin" />
    <bpmn:serviceTask id="Gateway_CreateWebhookEvent" name="Создать webhook_event" />
    <bpmn:sendTask id="Gateway_SendWebhook" name="Отправить webhook мерчанту" />
    <bpmn:serviceTask id="Gateway_MarkWebhookSent" name="Обновить webhook_events.status = SENT" />
    <bpmn:endEvent id="Gateway_End" name="Платеж обработан" />
    <bpmn:sequenceFlow id="Gateway_Flow_1" sourceRef="Gateway_Start" targetRef="Gateway_CheckApiKey" />
    <bpmn:sequenceFlow id="Gateway_Flow_2" sourceRef="Gateway_CheckApiKey" targetRef="Gateway_CheckIdempotency" />
    <bpmn:sequenceFlow id="Gateway_Flow_3" sourceRef="Gateway_CheckIdempotency" targetRef="Gateway_IdempotencyGateway" />
    <bpmn:sequenceFlow id="Gateway_Flow_Existing" name="Да" sourceRef="Gateway_IdempotencyGateway" targetRef="Gateway_GetExistingPayment" />
    <bpmn:sequenceFlow id="Gateway_Flow_Existing_2" sourceRef="Gateway_GetExistingPayment" targetRef="Gateway_SendPaymentResponse" />
    <bpmn:sequenceFlow id="Gateway_Flow_Existing_3" sourceRef="Gateway_SendPaymentResponse" targetRef="Gateway_EndExisting" />
    <bpmn:sequenceFlow id="Gateway_Flow_New" name="Нет" sourceRef="Gateway_IdempotencyGateway" targetRef="Gateway_CreatePayment" />
    <bpmn:sequenceFlow id="Gateway_Flow_4" sourceRef="Gateway_CreatePayment" targetRef="Gateway_SaveIdempotency" />
    <bpmn:sequenceFlow id="Gateway_Flow_5" sourceRef="Gateway_SaveIdempotency" targetRef="Gateway_CreateAttempt" />
    <bpmn:sequenceFlow id="Gateway_Flow_6" sourceRef="Gateway_CreateAttempt" targetRef="Gateway_SetProcessing" />
    <bpmn:sequenceFlow id="Gateway_Flow_7" sourceRef="Gateway_SetProcessing" targetRef="Gateway_SendToBank" />
    <bpmn:sequenceFlow id="Gateway_Flow_8" sourceRef="Gateway_SendToBank" targetRef="Gateway_CatchCallback" />
    <bpmn:sequenceFlow id="Gateway_Flow_9" sourceRef="Gateway_CatchCallback" targetRef="Gateway_FindAttempt" />
    <bpmn:sequenceFlow id="Gateway_Flow_10" sourceRef="Gateway_FindAttempt" targetRef="Gateway_ResultGateway" />
    <bpmn:sequenceFlow id="Gateway_Flow_Success" name="Да" sourceRef="Gateway_ResultGateway" targetRef="Gateway_SetSucceeded" />
    <bpmn:sequenceFlow id="Gateway_Flow_Fail" name="Нет" sourceRef="Gateway_ResultGateway" targetRef="Gateway_SetFailed" />
    <bpmn:sequenceFlow id="Gateway_Flow_11" sourceRef="Gateway_SetSucceeded" targetRef="Gateway_StatusJoin" />
    <bpmn:sequenceFlow id="Gateway_Flow_12" sourceRef="Gateway_SetFailed" targetRef="Gateway_StatusJoin" />
    <bpmn:sequenceFlow id="Gateway_Flow_13" sourceRef="Gateway_StatusJoin" targetRef="Gateway_CreateWebhookEvent" />
    <bpmn:sequenceFlow id="Gateway_Flow_14" sourceRef="Gateway_CreateWebhookEvent" targetRef="Gateway_SendWebhook" />
    <bpmn:sequenceFlow id="Gateway_Flow_15" sourceRef="Gateway_SendWebhook" targetRef="Gateway_MarkWebhookSent" />
    <bpmn:sequenceFlow id="Gateway_Flow_16" sourceRef="Gateway_MarkWebhookSent" targetRef="Gateway_End" />
    <bpmn:intermediateCatchEvent id="Gateway_CatchCallback" name="Получить callback от банка">
      <bpmn:messageEventDefinition id="MessageEventDefinition_Callback" />
    </bpmn:intermediateCatchEvent>
    <bpmn:association id="Association_Payment" sourceRef="Gateway_CreatePayment" targetRef="DataStore_PostgreSQL" />
    <bpmn:association id="Association_Idempotency" sourceRef="Gateway_SaveIdempotency" targetRef="DataStore_PostgreSQL" />
    <bpmn:association id="Association_Attempt" sourceRef="Gateway_CreateAttempt" targetRef="DataStore_PostgreSQL" />
    <bpmn:association id="Association_Webhook" sourceRef="Gateway_CreateWebhookEvent" targetRef="DataStore_PostgreSQL" />
    <bpmn:association id="Association_WebhookSent" sourceRef="Gateway_MarkWebhookSent" targetRef="DataStore_PostgreSQL" />
  </bpmn:process>
  <bpmn:process id="Process_Bank" isExecutable="false">
    <bpmn:serviceTask id="Bank_ProcessPayment" name="Обработать платеж" />
    <bpmn:sendTask id="Bank_SendCallback" name="Отправить результат оплаты" />
    <bpmn:endEvent id="Bank_End" name="Результат отправлен" />
    <bpmn:sequenceFlow id="Bank_Flow_1" sourceRef="Bank_Start" targetRef="Bank_ProcessPayment" />
    <bpmn:sequenceFlow id="Bank_Flow_2" sourceRef="Bank_ProcessPayment" targetRef="Bank_SendCallback" />
    <bpmn:sequenceFlow id="Bank_Flow_3" sourceRef="Bank_SendCallback" targetRef="Bank_End" />
    <bpmn:startEvent id="Bank_Start" name="Запрос получен" />
  </bpmn:process>
  <bpmn:process id="Process_MerchantSystem" isExecutable="false">
    <bpmn:startEvent id="MerchantSystem_Start" name="Ожидание webhook" />
    <bpmn:receiveTask id="MerchantSystem_ReceiveWebhook" name="Принять webhook" />
    <bpmn:serviceTask id="MerchantSystem_UpdateOrder" name="Обновить статус заказа" />
    <bpmn:endEvent id="MerchantSystem_End" name="Заказ обновлен" />
    <bpmn:sequenceFlow id="MerchantSystem_Flow_1" sourceRef="MerchantSystem_Start" targetRef="MerchantSystem_ReceiveWebhook" />
    <bpmn:sequenceFlow id="MerchantSystem_Flow_2" sourceRef="MerchantSystem_ReceiveWebhook" targetRef="MerchantSystem_UpdateOrder" />
    <bpmn:sequenceFlow id="MerchantSystem_Flow_3" sourceRef="MerchantSystem_UpdateOrder" targetRef="MerchantSystem_End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_PaymentGateway">
    <bpmndi:BPMNPlane id="BPMNPlane_PaymentGateway" bpmnElement="Collaboration_PaymentGateway">
      <bpmndi:BPMNShape id="Shape_Participant_Merchant" bpmnElement="Participant_Merchant" isHorizontal="true">
        <dc:Bounds x="120" y="60" width="1580" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Merchant_Start" bpmnElement="Merchant_Start">
        <dc:Bounds x="180" y="107" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Merchant_SendCreatePayment" bpmnElement="Merchant_SendCreatePayment">
        <dc:Bounds x="260" y="85" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Merchant_ReceivePaymentResponse" bpmnElement="Merchant_ReceivePaymentResponse">
        <dc:Bounds x="1480" y="85" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Merchant_End" bpmnElement="Merchant_End">
        <dc:Bounds x="1640" y="107" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Merchant_Flow_1" bpmnElement="Merchant_Flow_1">
        <di:waypoint x="216" y="125" />
