      <bpmndi:BPMNShape id="Shape_Gateway_IdempotencyGateway" bpmnElement="Gateway_IdempotencyGateway" isMarkerVisible="true">
        <dc:Bounds x="570" y="460" width="50" height="50" />
      </bpmndi:BPMNShape>
