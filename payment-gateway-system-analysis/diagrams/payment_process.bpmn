          <dc:Bounds x="1356" y="585.5" width="87" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_1" bpmnElement="Gateway_Flow_1">
        <di:waypoint x="216" y="485" />
        <di:waypoint x="250" y="485" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Gateway_Flow_2" bpmnElement="Gateway_Flow_2">
        <di:waypoint x="370" y="485" />
