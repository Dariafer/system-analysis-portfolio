      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Merchant_Flow_2" bpmnElement="Merchant_Flow_2">
        <di:waypoint x="400" y="125" />
        <di:waypoint x="1480" y="125" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Merchant_Flow_3" bpmnElement="Merchant_Flow_3">
        <di:waypoint x="1620" y="125" />
        <di:waypoint x="1640" y="125" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Participant_Gateway" bpmnElement="Participant_Gateway" isHorizontal="true">
        <dc:Bounds x="120" y="230" width="1620" height="520" />
      </bpmndi:BPMNShape>
